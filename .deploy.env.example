# Copy to .deploy.env and fill in real tokens.
# .deploy.env is gitignored.

# Vercel deploy token: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_SCOPE=boozybatsmains-projects
VERCEL_PROJECT=genex

# npm automation token (Classic → Automation type; bypasses 2FA):
# https://www.npmjs.com/settings/boozybats/tokens
NPM_TOKEN=

# Hosted endpoints (these are baked into the CLI defaults too):
GENEX_SERVER_URL=https://genex-server.onrender.com
GENEX_EDITOR_URL=https://genex-pi.vercel.app
GITHUB_REPO=boozybatsMain/genex
